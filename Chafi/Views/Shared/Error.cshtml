<!-- مسار الملف: Views/Shared/Error.cshtml -->
@model Chafi.Models.ErrorViewModel
@{
    ViewData["Title"] = "حدث خطأ";
}

<div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="max-w-md w-full bg-white rounded-3xl border-2 border-border p-8 text-center shadow-lg">
        <div class="w-24 h-24 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6 text-5xl">
            <i class="fas fa-exclamation-triangle"></i>
        </div>

        <h1 class="text-3xl font-black text-pri-900 font-amiri mb-3">عذراً، حدث خطأ!</h1>
        <p class="text-brk-500 text-sm leading-relaxed mb-6">لقد واجهنا مشكلة غير متوقعة أثناء معالجة طلبك. نرجو المحاولة مرة أخرى لاحقاً.</p>

        @if (Model.ShowRequestId)
        {
            <div class="bg-gray-50 rounded-xl p-4 mb-6 border border-gray-100 text-left" dir="ltr">
                <p class="text-xs text-brk-400 mb-1">Request ID:</p>
                <code class="text-sm font-mono text-pri-600">@Model.RequestId</code>
            </div>
        }

        <div class="flex gap-3 justify-center">
            <a href="@Url.Action("Index", "Home")" class="cf-btn cf-btn-pri cf-btn-sm">
                <i class="fas fa-home"></i> العودة للرئيسية
            </a>
            <button onclick="window.history.back()" class="cf-btn cf-btn-out cf-btn-sm">
                <i class="fas fa-arrow-right"></i> رجوع للخلف
            </button>
        </div>
    </div>
</div>