@model Chafi.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "الرئيسية";
}

<!-- هيرو سلايدر (دايناميك من قاعدة البيانات) -->
<section class="hero" id="heroSlider">
    @if (Model.HeroSliders != null && Model.HeroSliders.Any())
    {
        int index = 0;
        foreach (var slide in Model.HeroSliders)
        {
            <div class="hero-slide @(index == 0 ? "on" : "")" style="background:url('@slide.ImageUrl') center/cover">
                <div class="relative z-10 h-full flex items-center">
                    <div class="max-w-7xl mx-auto px-5 w-full">
                        <div class="max-w-lg @(index % 2 != 0 ? "mr-auto text-left" : "")" dir="@(index % 2 != 0 ? "ltr" : "rtl")">
                            @if (!string.IsNullOrEmpty(slide.Subtitle))
                            {
                                <span class="inline-block px-4 py-1 rounded-full bg-gld-500/90 text-pri-900 text-xs font-bold mb-3">@slide.Subtitle</span>
                            }
                            <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-white leading-tight mb-3 font-amiri" dir="rtl">
                                @Html.Raw(slide.Title.Replace("\n", "<br>"))
                            </h1>
                            @if (!string.IsNullOrEmpty(slide.LinkUrl))
                            {
                                <div class="flex gap-3 @(index % 2 != 0 ? "justify-start" : "")" dir="rtl">
                                    <a href="@slide.LinkUrl" class="cf-btn cf-btn-gld"><i class="fas fa-link"></i> تصفح الآن</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            index++;
        }
    }
    <!-- أزرار التحكم -->
    <button class="hero-arrow r" onclick="heroNav(1)"><i class="fas fa-chevron-left"></i></button>
    <button class="hero-arrow l" onclick="heroNav(-1)"><i class="fas fa-chevron-right"></i></button>
    <div class="hero-dots" id="heroDots"></div>
</section>

<!-- الأقسام الرئيسية (دايناميك) -->
<section class="max-w-7xl mx-auto px-4 mb-14 mt-12" id="catsSec">
    <div class="text-center mb-9">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-pri-900 mb-2">أقسام المتجر</h2>
        <div class="orn"><div class="orn-ln"></div><div class="orn-dm"></div><div class="orn-ln"></div></div>
        <p class="text-brk-500 text-base max-w-lg mx-auto">تصفح أقسامنا المتنوعة وكلها تحت إشراف وإدارة الموقع</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        @foreach (var cat in Model.MainCategories)
        {
            <a href="@Url.Action("Details", "Category", new { id = cat.Id, slug = cat.Slug })" class="cat-card block no-underline">
                <div class="cat-ico" style="background:linear-gradient(135deg,@(cat.ColorHex ?? "#1a582a")12,@(cat.ColorHex ?? "#1a582a")22);color:@(cat.ColorHex ?? "#1a582a")">
                    <i class="@(cat.IconClass ?? "fas fa-folder")"></i>
                </div>
                <h3 class="font-bold text-pri-900 text-sm mb-1">@cat.Name</h3>
                <p class="text-brk-400 text-[11px] leading-relaxed">@cat.ShortDescription</p>
            </a>
        }
    </div>
</section>

<section class="max-w-7xl mx-auto px-4 mb-14" id="prodSec">
    <div class="flex items-end justify-between mb-9">
        <div>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-pri-900 mb-2">المنتجات المختارة</h2>
            <div class="orn" style="padding-bottom:0"><div class="orn-ln"></div><div class="orn-dm"></div><div class="orn-ln"></div></div>
        </div>
        <a href="@Url.Action("Index", "Product")" class="cf-btn cf-btn-out cf-btn-sm hidden sm:flex">عرض الكل <i class="fas fa-arrow-left mr-1 text-xs"></i></a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        @foreach (var prod in Model.FeaturedProducts)
        {
            <div class="prod-card">
                @if (prod.HasDiscount)
                {
                    <span class="prod-badge offer">خصم @prod.DiscountPercentage%</span>
                }
                <div class="prod-img-w">
                    <img src="@prod.ImageUrl" alt="@prod.Name" loading="lazy">
                </div>
                <div class="p-4">
                    <h4 class="font-bold text-pri-900 text-sm mb-1.5 leading-relaxed line-clamp-2" style="min-height:40px">@prod.Name</h4>
                    <div class="flex items-center justify-between">
                        <div>
                            @if (prod.HasDiscount)
                            {
                                <span class="text-brk-300 text-xs line-through ml-1">@prod.OldPrice ر.س</span>
                            }
                            <span class="text-pri-700 font-black text-lg">@prod.Price ر.س</span>
                        </div>
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="productId" value="@prod.Id" />
                            <button type="submit" class="cf-btn cf-btn-pri cf-btn-sm text-xs py-2 px-3"><i class="fas fa-cart-plus"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</section>