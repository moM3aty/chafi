<!-- مسار الملف: Views/Admin/CreateVideo.cshtml -->
@model Chafi.Models.Video
@{
    ViewData["Title"] = "إضافة فيديو جديد";
}

<div class="max-w-4xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-video text-gld-500 ml-2"></i>إضافة فيديو تعليمي</h1>
        <a href="@Url.Action("Videos")" class="cf-btn cf-btn-out cf-btn-sm text-xs">
            <i class="fas fa-arrow-right"></i> العودة للفيديوهات
        </a>
    </div>

    <div class="bg-white rounded-3xl border-2 border-border p-6 sm:p-10 shadow-sm">
        <form asp-action="CreateVideo" method="post" enctype="multipart/form-data">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">عنوان الفيديو <span class="req">*</span></label>
                    <input asp-for="Title" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">القسم التابع له <span class="req">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="cf-select" required>
                        <option value="">اختر القسم...</option>
                    </select>
                </div>
            </div>

            <div class="cf-group mb-6">
                <label class="cf-label">المقدم / الراقي</label>
                <input asp-for="Presenter" class="cf-input" placeholder="اسم مقدم الفيديو" />
            </div>

            <div class="cf-group mb-6">
                <label class="cf-label">الوصف</label>
                <textarea asp-for="Description" class="cf-textarea" rows="4"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">ملف الفيديو (MP4) <span class="req">*</span></label>
                    <input type="file" name="VideoFile" accept="video/mp4,video/x-m4v,video/*" class="cf-input p-2" required />
                    <p class="text-[11px] text-brk-400 mt-1">يُفضل أن يكون بصيغة MP4 ومضغوطاً لتسريع التحميل</p>
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">صورة الغلاف (Thumbnail)</label>
                    <input type="file" name="ThumbnailFile" accept="image/*" class="cf-input p-2" required />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 border-t border-gray-100 pt-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">السعر (ر.س) <span class="req">*</span></label>
                    <input asp-for="Price" type="number" step="0.01" value="0" class="cf-input" />
                    <p class="text-[11px] text-brk-400 mt-1">اتركه 0 إذا كان الفيديو مجانياً للمشاهدة.</p>
                </div>

                <div class="flex items-center gap-6 mt-8">
                    <label class="cf-check-wrap font-bold text-pri-900">
                        <input asp-for="IsActive" type="checkbox" class="cf-check" checked /> مفعل
                    </label>
                </div>
            </div>

            <button type="submit" class="cf-btn cf-btn-gld cf-btn-lg w-full md:w-auto">
                <i class="fas fa-upload"></i> رفع وحفظ الفيديو
            </button>
        </form>
    </div>
</div>