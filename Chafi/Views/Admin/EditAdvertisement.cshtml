<!-- مسار الملف: Views/Admin/EditAdvertisement.cshtml -->
@model Chafi.Models.Advertisement
@{
    ViewData["Title"] = "تعديل الإعلان";
}

<div class="max-w-4xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-edit text-gld-500 ml-2"></i>تعديل الإعلان</h1>
        <a href="@Url.Action("Advertisements")" class="cf-btn cf-btn-out cf-btn-sm text-xs">
            <i class="fas fa-arrow-right"></i> العودة للإعلانات
        </a>
    </div>

    <div class="bg-white rounded-3xl border-2 border-border p-6 sm:p-10 shadow-sm">
        <form asp-action="EditAdvertisement" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">عنوان الإعلان <span class="req">*</span></label>
                    <input asp-for="Title" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">العنوان الفرعي</label>
                    <input asp-for="Subtitle" class="cf-input" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">موضع الإعلان <span class="req">*</span></label>
                    <select asp-for="Position" class="cf-select" required>
                        <option value="0">سلايدر رئيسي</option>
                        <option value="1">بانر علوي</option>
                        <option value="2">شريط جانبي</option>
                    </select>
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">الرابط (اختياري)</label>
                    <input asp-for="LinkUrl" type="url" class="cf-input" dir="ltr" />
                </div>
            </div>

            <div class="cf-group mb-8">
                <label class="cf-label">تحديث الصورة (اتركه فارغاً للاحتفاظ بالحالية)</label>
                <input type="file" name="ImageFile" accept="image/*" class="cf-input p-2" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-3">
                        <img src="@Model.ImageUrl" class="h-20 rounded object-cover border border-gray-200">
                    </div>
                }
            </div>

            <div class="flex gap-6 mb-8 border-t border-gray-100 pt-6">
                <label class="cf-check-wrap font-bold text-pri-900">
                    <input asp-for="IsActive" type="checkbox" class="cf-check" /> مفعل
                </label>
            </div>

            <button type="submit" class="cf-btn cf-btn-pri cf-btn-lg w-full md:w-auto">
                <i class="fas fa-save"></i> حفظ التعديلات
            </button>
        </form>
    </div>
</div>