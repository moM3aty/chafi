@model IEnumerable<Chafi.Models.NewsletterSubscription>
@{
    ViewData["Title"] = "المشتركون بالنشرة البريدية";
}

<div class="max-w-7xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-users text-gld-500 ml-2"></i>المشتركون في النشرة</h1>
    </div>

    <div class="bg-white rounded-2xl border-2 border-border overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-right text-sm">
                <thead class="bg-gray-50 border-b border-gray-100 text-brk-500">
                    <tr>
                        <th class="p-4 font-bold">البريد الإلكتروني</th>
                        <th class="p-4 font-bold text-center">تاريخ الاشتراك</th>
                        <th class="p-4 font-bold text-center">الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                                <td class="p-4 font-bold text-pri-900" dir="ltr">@item.Email</td>
                                <td class="p-4 text-center text-brk-500">@item.SubscribedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="p-4 text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">نشط</span>
                                    }
                                    else
                                    {

                                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">ملغى</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="p-8 text-center text-brk-400">لا يوجد مشتركون حتى الآن</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>