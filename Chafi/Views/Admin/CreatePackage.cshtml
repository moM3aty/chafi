<!-- مسار الملف: Views/Admin/CreatePackage.cshtml -->
@model Chafi.Models.Package
@{
    ViewData["Title"] = "إضافة باقة جديدة";
}

<div class="max-w-4xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-box-open text-gld-500 ml-2"></i>إضافة باقة جديدة</h1>
        <a href="@Url.Action("Packages")" class="cf-btn cf-btn-out cf-btn-sm text-xs">
            <i class="fas fa-arrow-right"></i> العودة للباقات
        </a>
    </div>

    <div class="bg-white rounded-3xl border-2 border-border p-6 sm:p-10 shadow-sm">
        <form asp-action="CreatePackage" method="post" enctype="multipart/form-data">

            <div class="cf-group mb-6">
                <label class="cf-label">اسم الباقة <span class="req">*</span></label>
                <input asp-for="Name" class="cf-input" required />
            </div>

            <div class="cf-group mb-6">
                <label class="cf-label">وصف الباقة <span class="req">*</span></label>
                <textarea asp-for="Description" class="cf-textarea" rows="4" required></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">إجمالي السعر الأصلي (ر.س) <span class="req">*</span></label>
                    <input asp-for="OriginalTotalPrice" type="number" step="0.01" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">سعر الباقة (بعد التخفيض) <span class="req">*</span></label>
                    <input asp-for="PackagePrice" type="number" step="0.01" class="cf-input" required />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div class="cf-group !mb-0">
                    <label class="cf-label">صورة الباقة (ملف من الجهاز)</label>
                    <input type="file" name="ImageFile" accept="image/*" class="cf-input p-2" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">الحد الأقصى للشراء (اختياري)</label>
                    <input asp-for="MaxPurchasesPerUser" type="number" class="cf-input" placeholder="مثال: 1" />
                </div>
            </div>

            <div class="flex gap-6 mb-8 border-t border-gray-100 pt-6">
                <label class="cf-check-wrap font-bold text-pri-900">
                    <input asp-for="IsActive" type="checkbox" class="cf-check" checked /> مفعلة
                </label>
                <label class="cf-check-wrap font-bold text-gld-600">
                    <input asp-for="IsFeatured" type="checkbox" class="cf-check" /> باقة مميزة
                </label>
            </div>

            <button type="submit" class="cf-btn cf-btn-gld cf-btn-lg w-full md:w-auto">
                <i class="fas fa-save"></i> حفظ الباقة
            </button>
        </form>
    </div>
</div>