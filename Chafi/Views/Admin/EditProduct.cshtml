<!-- مسار الملف: Views/Admin/EditProduct.cshtml -->
@model Chafi.Models.Product
@{
    ViewData["Title"] = "تعديل المنتج";
}

<div class="max-w-4xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-edit text-gld-500 ml-2"></i>تعديل منتج</h1>
        <a href="@Url.Action("Products", "Admin")" class="cf-btn cf-btn-out cf-btn-sm text-xs">
            <i class="fas fa-arrow-right"></i> العودة للمنتجات
        </a>
    </div>

    <div class="bg-white rounded-3xl border-2 border-border p-6 sm:p-10 shadow-sm">
        <form asp-action="EditProduct" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="Slug" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">اسم المنتج <span class="req">*</span></label>
                    <input asp-for="Name" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">القسم التابع له <span class="req">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="cf-select" required></select>
                </div>
            </div>

            <div class="cf-group mb-6">
                <label class="cf-label">وصف المنتج <span class="req">*</span></label>
                <textarea asp-for="Description" class="cf-textarea" rows="4" required></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">السعر (ر.س) <span class="req">*</span></label>
                    <input asp-for="Price" type="number" step="0.01" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">السعر القديم (اختياري)</label>
                    <input asp-for="OldPrice" type="number" step="0.01" class="cf-input" />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">الكمية المتوفرة <span class="req">*</span></label>
                    <input asp-for="StockQuantity" type="number" class="cf-input" required />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 items-center">
                <div class="cf-group !mb-0">
                    <label class="cf-label">نوع المنتج</label>
                    <select asp-for="ProductType" class="cf-select">
                        <option value="0">منتج مادي</option>
                        <option value="1">منتج رقمي</option>
                    </select>
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">تحديث الصورة (اتركه فارغاً للاحتفاظ بالحالية)</label>
                    <input type="file" name="ImageFile" accept="image/*" class="cf-input p-2" />
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mt-2 flex items-center gap-2">
                            <img src="@Model.ImageUrl" class="w-10 h-10 rounded border border-gray-200 object-cover" />
                            <span class="text-[10px] text-brk-400">الصورة الحالية</span>
                        </div>
                    }
                </div>
            </div>

            <div class="flex gap-6 mb-8 border-t border-gray-100 pt-6">
                <label class="cf-check-wrap font-bold text-pri-900">
                    <input asp-for="IsActive" type="checkbox" class="cf-check" /> مفعل
                </label>
                <label class="cf-check-wrap font-bold text-gld-600">
                    <input asp-for="IsFeatured" type="checkbox" class="cf-check" /> منتج مميز
                </label>
            </div>

            <button type="submit" class="cf-btn cf-btn-pri cf-btn-lg w-full md:w-auto">
                <i class="fas fa-save"></i> حفظ التعديلات
            </button>
        </form>
    </div>
</div>