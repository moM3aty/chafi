<!-- مسار الملف: Views/Admin/EditCategory.cshtml -->
@model Chafi.Models.Category
@{
    ViewData["Title"] = "تعديل القسم";
}

<div class="max-w-4xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-edit text-gld-500 ml-2"></i>تعديل القسم</h1>
        <a href="@Url.Action("Categories")" class="cf-btn cf-btn-out cf-btn-sm text-xs">
            <i class="fas fa-arrow-right"></i> العودة للأقسام
        </a>
    </div>

    <div class="bg-white rounded-3xl border-2 border-border p-6 sm:p-10 shadow-sm">
        <form asp-action="EditCategory" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Slug" />
            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">اسم القسم <span class="req">*</span></label>
                    <input asp-for="Name" class="cf-input" required />
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">الوصف المختصر</label>
                    <input asp-for="ShortDescription" class="cf-input" />
                </div>
            </div>

            <div class="cf-group mb-6">
                <label class="cf-label">الوصف الشامل (التعريف)</label>
                <textarea asp-for="Description" class="cf-textarea" rows="5"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="cf-group !mb-0">
                    <label class="cf-label">القسم الأب (اختياري)</label>
                    <select asp-for="ParentId" asp-items="ViewBag.ParentId" class="cf-select">
                        <option value="">-- قسم رئيسي --</option>
                    </select>
                </div>

                <div class="cf-group !mb-0">
                    <label class="cf-label">أيقونة القسم (FontAwesome)</label>
                    <input asp-for="IconClass" class="cf-input" dir="ltr" />
                </div>
            </div>

            <div class="cf-group mb-8">
                <label class="cf-label">تحديث الصورة (اتركه فارغاً للاحتفاظ بالحالية)</label>
                <input type="file" name="ImageFile" accept="image/*" class="cf-input p-2" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-3 flex items-center gap-3">
                        <img src="@Model.ImageUrl" class="w-12 h-12 rounded object-cover border border-gray-200">
                        <span class="text-xs text-brk-400">الصورة الحالية للقسم</span>
                    </div>
                }
            </div>

            <div class="flex gap-6 mb-8 border-t border-gray-100 pt-6">
                <label class="cf-check-wrap font-bold text-pri-900">
                    <input asp-for="IsActive" type="checkbox" class="cf-check" /> مفعل
                </label>
                <label class="cf-check-wrap font-bold text-pri-900">
                    <input asp-for="ShowInMainMenu" type="checkbox" class="cf-check" /> إظهار في القائمة العلوية
                </label>
            </div>

            <button type="submit" class="cf-btn cf-btn-pri cf-btn-lg w-full md:w-auto">
                <i class="fas fa-save"></i> حفظ التعديلات
            </button>
        </form>
    </div>
</div>