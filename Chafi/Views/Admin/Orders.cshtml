<!-- مسار الملف: Views/Admin/Orders.cshtml -->
@model IEnumerable<Chafi.Models.Order>
@{
    ViewData["Title"] = "إدارة الطلبات";
}

<div class="max-w-7xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-shopping-cart text-gld-500 ml-2"></i>إدارة الطلبات</h1>
    </div>

    <div class="bg-white rounded-2xl border-2 border-border overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-right text-sm">
                <thead class="bg-gray-50 border-b border-gray-100 text-brk-500">
                    <tr>
                        <th class="p-4 font-bold">رقم الطلب</th>
                        <th class="p-4 font-bold">التاريخ</th>
                        <th class="p-4 font-bold">العميل</th>
                        <th class="p-4 font-bold text-center">الإجمالي</th>
                        <th class="p-4 font-bold text-center">الحالة</th>
                        <th class="p-4 font-bold text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                                <td class="p-4 font-bold text-pri-900">@order.OrderNumber</td>
                                <td class="p-4 text-brk-500">@order.CreatedAtFormatted</td>
                                <td class="p-4 text-brk-500">@order.User?.FullName <br><span class="text-xs text-gray-400">@order.Phone</span></td>
                                <td class="p-4 text-center font-bold text-pri-700">@order.TotalAmount ر.س</td>
                                <td class="p-4 text-center">
                                    @{
                                        string statusClass = order.Status == Chafi.Models.OrderStatus.Pending ? "bg-yellow-100 text-yellow-700" :
                                        order.Status == Chafi.Models.OrderStatus.Confirmed ? "bg-blue-100 text-blue-700" :
                                        order.Status == Chafi.Models.OrderStatus.Delivered ? "bg-green-100 text-green-700" :
                                        "bg-gray-100 text-gray-700";
                                    }
                                    <span class="@statusClass px-2 py-1 rounded text-xs">@order.Status</span>
                                </td>
                                <td class="p-4 flex justify-center gap-2">
                                    <button class="w-8 h-8 rounded bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition flex items-center justify-center" title="عرض التفاصيل"><i class="fas fa-eye"></i></button>
                                    <button class="w-8 h-8 rounded bg-green-50 text-green-600 hover:bg-green-600 hover:text-white transition flex items-center justify-center" title="تحديث الحالة"><i class="fas fa-check"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="p-8 text-center text-brk-400">لا توجد طلبات حتى الآن</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>