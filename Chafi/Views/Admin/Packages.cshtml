<!-- مسار الملف: Views/Admin/Packages.cshtml -->
@model IEnumerable<Chafi.Models.Package>
@{
    ViewData["Title"] = "إدارة الباقات";
}

<div class="max-w-7xl mx-auto px-4 py-8 mb-14">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-black text-pri-900 font-amiri"><i class="fas fa-boxes text-gld-500 ml-2"></i>إدارة الباقات</h1>
        <a href="@Url.Action("CreatePackage")" class="cf-btn cf-btn-gld cf-btn-sm">
            <i class="fas fa-plus"></i> إضافة باقة جديدة
        </a>
    </div>

    <div class="bg-white rounded-2xl border-2 border-border overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-right text-sm">
                <thead class="bg-gray-50 border-b border-gray-100 text-brk-500">
                    <tr>
                        <th class="p-4 font-bold">اسم الباقة</th>
                        <th class="p-4 font-bold text-center">السعر الأصلي</th>
                        <th class="p-4 font-bold text-center">سعر الباقة</th>
                        <th class="p-4 font-bold text-center">المبيعات</th>
                        <th class="p-4 font-bold text-center">الحالة</th>
                        <th class="p-4 font-bold text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                                <td class="p-4 flex items-center gap-3">
                                    <img src="@(item.ImageUrl ?? "https://picsum.photos/50")" class="w-10 h-10 rounded object-cover border border-gray-200">
                                    <span class="font-bold text-pri-900">@item.Name</span>
                                    @if (item.IsFeatured)
                                    {
                                        <span class="bg-gld-100 text-gld-700 px-2 py-0.5 rounded text-[10px]">مميزة</span>
                                    }
                                </td>
                                <td class="p-4 text-center text-brk-400 line-through">@item.OriginalTotalPrice ر.س</td>
                                <td class="p-4 text-center font-bold text-pri-700">@item.PackagePrice ر.س</td>
                                <td class="p-4 text-center text-brk-500">@item.SalesCount</td>
                                <td class="p-4 text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">مفعلة</span>
                                    }
                                    else
                                    {

                                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">معطلة</span>
                                    }
                                </td>
                                <td class="p-4 flex justify-center gap-2">
                                    <button class="w-8 h-8 rounded bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition flex items-center justify-center" title="تعديل"><i class="fas fa-edit"></i></button>
                                    <button class="w-8 h-8 rounded bg-red-50 text-red-600 hover:bg-red-600 hover:text-white transition flex items-center justify-center" title="حذف"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="p-8 text-center text-brk-400">لا توجد باقات حتى الآن</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>