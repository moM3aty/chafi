<!-- مسار الملف: Views/Cart/Index.cshtml -->
@model Chafi.Models.Cart
@{
    ViewData["Title"] = "سلة التسوق";
}

<div class="max-w-7xl mx-auto px-4 py-10 mb-14">
    <div class="flex items-center gap-3 mb-8">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gld-400 to-gld-600 flex items-center justify-center text-pri-900 text-xl shadow-lg">
            <i class="fas fa-shopping-cart"></i>
        </div>
        <h1 class="text-3xl font-black text-pri-900 font-amiri">سلة التسوق</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- قائمة المنتجات -->
        <div class="lg:col-span-2">
            @if (Model == null || !Model.Items.Any())
            {
                <div class="bg-white rounded-2xl p-10 text-center border-2 border-border">
                    <i class="fas fa-cart-arrow-down text-5xl text-brk-300 mb-4 opacity-50"></i>
                    <h3 class="text-xl font-bold text-pri-900 mb-2">سلة التسوق فارغة</h3>
                    <p class="text-brk-400 mb-6">لم تقم بإضافة أي منتجات إلى سلتك حتى الآن.</p>
                    <a href="@Url.Action("Index", "Home")" class="cf-btn cf-btn-pri inline-flex"><i class="fas fa-store"></i> العودة للمتجر</a>
                </div>
            }
            else
            {
                <div class="bg-white rounded-2xl border-2 border-border overflow-hidden">
                    @foreach (var item in Model.Items)
                    {
                        <div class="p-5 flex gap-4 border-b border-gray-100 last:border-0 hover:bg-gray-50 transition">
                            <img src="@(item.ItemImage ?? "https://picsum.photos/200")" alt="@item.ItemName" class="w-24 h-24 rounded-xl object-cover border border-gray-200 shrink-0">
                            <div class="flex-1 min-w-0 flex flex-col justify-between">
                                <div>
                                    <h4 class="font-bold text-pri-900 text-base mb-1 truncate">@item.ItemName</h4>
                                    <div class="text-pri-600 font-bold text-sm">@item.UnitPrice ر.س للوحدة</div>
                                </div>
                                <div class="flex items-center justify-between mt-3">
                                    <div class="qty bg-white">
                                        <button class="qty-b">-</button>
                                        <input type="text" value="@item.Quantity" class="qty-v" readonly>
                                        <button class="qty-b">+</button>
                                    </div>
                                    <form asp-action="RemoveFromCart" method="post">
                                        <input type="hidden" name="itemId" value="@item.Id" />
                                        <button type="submit" class="text-red-500 hover:text-red-700 transition text-sm bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                                            <i class="fas fa-trash-alt"></i> إزالة
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ملخص الطلب -->
        @if (Model != null && Model.Items.Any())
        {
            <div>
                <div class="bg-white rounded-2xl border-2 border-border p-6 sticky top-24">
                    <h3 class="text-lg font-black text-pri-900 mb-5 border-b border-gray-100 pb-3">ملخص الطلب</h3>

                    <div class="space-y-3 text-sm text-brk-500 mb-5">
                        <div class="flex justify-between">
                            <span>المجموع الفرعي (@Model.TotalItems عناصر)</span>
                            <span class="font-bold">@Model.SubTotal ر.س</span>
                        </div>
                        <div class="flex justify-between">
                            <span>تكلفة الشحن</span>
                            <span class="text-pri-600 font-bold">يحدد لاحقاً</span>
                        </div>
                    </div>

                    <div class="border-t border-gray-100 pt-4 mb-6">
                        <div class="flex justify-between items-center">
                            <span class="text-base font-bold text-pri-900">الإجمالي الكلي</span>
                            <span class="text-2xl font-black text-pri-700">@Model.SubTotal ر.س</span>
                        </div>
                    </div>

                    <a href="#" class="cf-btn cf-btn-pri cf-btn-full cf-btn-lg justify-center no-underline" onclick="alert('سيتم تحويلك لصفحة الدفع وإتمام الطلب')">
                        <i class="fas fa-credit-card"></i> متابعة للدفع
                    </a>

                    <div class="mt-4 flex items-center justify-center gap-2">
                        <i class="fab fa-cc-visa text-gray-400 text-2xl"></i>
                        <i class="fab fa-cc-mastercard text-gray-400 text-2xl"></i>
                        <i class="fab fa-apple-pay text-gray-400 text-2xl"></i>
                    </div>
                </div>
            </div>
        }
    </div>
</div>