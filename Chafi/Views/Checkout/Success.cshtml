<!-- مسار الملف: Views/Checkout/Success.cshtml -->
@model Chafi.Models.Order
@{
    ViewData["Title"] = "تم تأكيد الطلب بنجاح";
}

<div class="max-w-3xl mx-auto px-4 py-16 mb-14 text-center">
    <div class="w-24 h-24 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <i class="fas fa-check-circle text-6xl text-green-500"></i>
    </div>

    <h1 class="text-3xl sm:text-4xl font-black text-pri-900 font-amiri mb-4">شكراً لك، تم استلام طلبك بنجاح!</h1>
    <p class="text-brk-500 text-lg mb-8">نقدر ثقتك في متجر تشافي. سيتم تجهيز طلبك في أسرع وقت ممكن.</p>

    <div class="bg-white rounded-3xl border-2 border-border p-8 mb-8 text-right shadow-sm relative overflow-hidden">
        <div class="absolute top-0 left-0 w-2 h-full bg-gld-500"></div>
        <h3 class="text-xl font-bold text-pri-900 mb-6 border-b border-gray-100 pb-4">تفاصيل الطلب</h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
            <div>
                <p class="text-brk-400 mb-1">رقم الطلب:</p>
                <p class="font-black text-pri-900 text-lg">@Model.OrderNumber</p>
            </div>
            <div>
                <p class="text-brk-400 mb-1">تاريخ الطلب:</p>
                <p class="font-bold text-pri-900">@Model.CreatedAtFormatted</p>
            </div>
            <div>
                <p class="text-brk-400 mb-1">الإجمالي المدفوع:</p>
                <p class="font-black text-pri-700 text-lg">@Model.TotalAmount ر.س</p>
            </div>
            <div>
                <p class="text-brk-400 mb-1">حالة الطلب:</p>
                <p class="font-bold text-gld-600 bg-gld-50 inline-block px-3 py-1 rounded-lg">قيد الانتظار / المراجعة</p>
            </div>
        </div>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="@Url.Action("Dashboard", "User")" class="cf-btn cf-btn-pri cf-btn-lg">
            <i class="fas fa-box-open"></i> تتبع الطلب
        </a>
        <a href="@Url.Action("Index", "Home")" class="cf-btn cf-btn-out cf-btn-lg">
            <i class="fas fa-home"></i> العودة للرئيسية
        </a>
    </div>
</div>